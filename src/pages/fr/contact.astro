---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import StatusPage from "../../components/StatusPage.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n/ui";
const lang = "fr" as const;
const s = t(lang);
---
<Base lang={lang} path="contact" title={s.contactTitle} description={s.contactBody}>
  <Header lang={lang} path="contact" />
  <main id="main">
    <StatusPage
      eyebrow={s.eyebrow}
      h1={s.contactH1}
      body={s.contactBody}
      ctaHref="mailto:hello@aptelle.com"
      ctaLabel={s.contactCta}
      icon="lucide:mail"
      subHref="mailto:hello@aptelle.com"
      subLabel="hello@aptelle.com"
    />
  </main>
  <Footer lang={lang} />
</Base>
