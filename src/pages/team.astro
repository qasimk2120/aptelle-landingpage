---
import { Icon } from "astro-icon/components";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const lang = "en" as const;

const team = [
  {
    initials: "MQ",
    name: "Muhammad Qasim",
    title: "Founder / CTO",
    bio: "Builds Aptelle end to end and everything else under CogniElevate. Started this because buying clothes online should not feel like a gamble.",
  },
  {
    initials: "HM",
    name: "Hafsa Mustafa",
    title: "Cofounder",
    bio: "Shapes how Aptelle should feel to the people who actually shop. Keeps the product honest about the sizing problem it set out to fix.",
  },
];
---
<Base
  lang={lang}
  path="team"
  localized={false}
  title="Team | Aptelle"
  description="The two people building Aptelle, the fit intelligence layer for online fashion, and why we started it."
>
  <Header lang={lang} path="team" />
  <main id="main" class="team-page legal-page">
    <section class="wrap team">
      <p class="eyebrow">Meet the team</p>
      <h1>The people behind <span class="accent">your right size</span></h1>

      <div class="story">
        <p>Buying clothes online is a gamble. Every brand sizes differently, so an M in one place is an L in another, and you only find out after it lands at your door.</p>
        <p>So we are building the fit layer. Tell Aptelle the sizes you already own and it tells you your size in any brand before you buy, with a confidence score you can trust. Small team on purpose, building in the open. Here is who is behind it.</p>
      </div>

      <div class="grid">
        {team.map((m) => (
          <article class="person">
            <div class="photo" aria-hidden="true">
              <Icon name="lucide:user-round" />
              <span class="badge" translate="no">{m.initials}</span>
            </div>
            <div class="pbody">
              <h2 translate="no">{m.name}</h2>
              <p class="role">{m.title}</p>
              <p class="bio">{m.bio}</p>
            </div>
          </article>
        ))}
      </div>

      <p class="foot">Want in early? <a href="/">Join the waitlist</a> or reach us at <a href="mailto:hello@aptelle.com">hello@aptelle.com</a>.</p>
    </section>
  </main>
  <Footer lang={lang} />
</Base>

<style>
  /* Background dust + gold-wash + min-height come from the shared .legal-page
     class in global.css, so this page matches contact, terms and privacy. */
  .team-page {
    padding-block: clamp(64px, 12vh, 140px) clamp(48px, 10vh, 120px);
  }
  .team {
    max-width: 1080px;
  }
  .eyebrow {
    color: var(--champagne);
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .team-page h1 {
    max-width: none;
    font-size: clamp(2.1rem, 5vw, 3.4rem);
    line-height: 1.06;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .team-page h1 .accent {
    color: var(--champagne);
    font-style: italic;
  }
  .story {
    margin-top: 20px;
    max-width: 66ch;
    display: grid;
    gap: 14px;
  }
  .story p {
    color: var(--muted);
    font-size: clamp(1.02rem, 1.6vw, 1.18rem);
    line-height: 1.65;
  }
  .grid {
    margin-top: clamp(40px, 7vh, 72px);
    display: grid;
    gap: clamp(20px, 3vw, 30px);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  @media (max-width: 620px) {
    .grid { grid-template-columns: 1fr; }
  }
  .person {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.18s ease, border-color 0.18s ease;
  }
  .person:hover {
    transform: translateY(-3px);
    border-color: rgba(242, 213, 146, 0.4);
  }
  .photo {
    position: relative;
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    background:
      radial-gradient(120% 120% at 50% 30%, rgba(242, 213, 146, 0.16), transparent 60%),
      linear-gradient(160deg, #17140d, #0c0b08);
    border-bottom: 1px solid var(--line);
  }
  .photo svg {
    width: 34%;
    height: auto;
    color: rgba(242, 213, 146, 0.55);
  }
  .badge {
    position: absolute;
    inset-inline-end: 14px;
    bottom: 14px;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--bronze), var(--gold) 55%, var(--champagne));
    color: #0b0906;
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }
  .pbody {
    padding: clamp(20px, 2.6vw, 28px);
  }
  .person h2 {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .role {
    margin-top: 4px;
    color: var(--champagne);
    font-weight: 600;
    font-size: 0.98rem;
  }
  .bio {
    margin-top: 14px;
    color: var(--muted);
    line-height: 1.6;
  }
  .foot {
    margin-top: clamp(40px, 7vh, 72px);
    color: var(--muted);
    font-size: 1.02rem;
  }
  .foot a {
    color: var(--champagne);
    font-weight: 600;
    text-decoration: none;
  }
  .foot a:hover {
    text-decoration: underline;
  }
</style>
