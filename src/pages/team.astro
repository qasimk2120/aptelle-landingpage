---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const lang = "en" as const;

const team = [
  {
    initials: "MQ",
    name: "Muhammad Qasim",
    title: "Founder / CTO",
    bio: "Builds Aptelle end to end and everything else under CogniElevate. Started this because buying clothes online should not feel like a gamble.",
  },
  {
    initials: "HM",
    name: "Hafsa Mustafa",
    title: "Cofounder",
    bio: "Shapes how Aptelle should feel to the people who actually shop. Keeps the product honest about the sizing problem it set out to fix.",
  },
];
---
<Base
  lang={lang}
  path="team"
  localized={false}
  title="Team | Aptelle"
  description="The two people building Aptelle, the fit intelligence layer for online fashion."
>
  <Header lang={lang} path="team" />
  <main id="main" class="team-page legal-page">
    <section class="wrap team">
      <p class="eyebrow">The people building it</p>
      <h1>Meet the <span class="accent">Team</span></h1>
      <p class="lead">Aptelle is small on purpose. No committee, no filler. Just the two of us shipping the fit layer for online fashion.</p>

      <div class="grid">
        {team.map((m) => (
          <article class="member">
            <div class="tile" aria-hidden="true"><span translate="no">{m.initials}</span></div>
            <h2 translate="no">{m.name}</h2>
            <p class="role">{m.title}</p>
            <p class="bio">{m.bio}</p>
          </article>
        ))}
      </div>

      <p class="foot">Want in early? <a href="/">Join the waitlist</a> or reach us at <a href="mailto:hello@aptelle.com">hello@aptelle.com</a>.</p>
    </section>
  </main>
  <Footer lang={lang} />
</Base>

<style>
  /* Background dust + gold-wash + min-height come from the shared .legal-page
     class in global.css, so this page matches contact, terms and privacy. */
  .team-page {
    padding-block: clamp(64px, 12vh, 140px) clamp(48px, 10vh, 120px);
  }
  .team {
    max-width: 1100px;
  }
  .eyebrow {
    color: var(--champagne);
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  h1 {
    max-width: none;
    font-size: clamp(2.1rem, 5vw, 3.4rem);
    line-height: 1.06;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-wrap: nowrap;
  }
  h1 .accent {
    color: var(--champagne);
    font-style: italic;
  }
  .lead {
    margin-top: 18px;
    max-width: 72ch;
    color: var(--muted);
    font-size: clamp(1.02rem, 1.6vw, 1.2rem);
    line-height: 1.6;
    text-wrap: pretty;
  }
  .grid {
    margin-top: clamp(40px, 7vh, 72px);
    display: grid;
    gap: clamp(20px, 3vw, 32px);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }
  .member {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: clamp(24px, 3vw, 36px);
  }
  .tile {
    width: 72px;
    height: 72px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    margin-bottom: 22px;
    background: linear-gradient(135deg, var(--bronze), var(--gold) 55%, var(--champagne));
    color: #0b0906;
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: 0.02em;
  }
  .member h2 {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .role {
    margin-top: 4px;
    color: var(--champagne);
    font-weight: 600;
    font-size: 0.98rem;
  }
  .bio {
    margin-top: 14px;
    color: var(--muted);
    line-height: 1.6;
  }
  .foot {
    margin-top: clamp(40px, 7vh, 72px);
    color: var(--muted);
    font-size: 1.02rem;
  }
  .foot a {
    color: var(--champagne);
    font-weight: 600;
    text-decoration: none;
  }
  .foot a:hover {
    text-decoration: underline;
  }
</style>
