---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const lang = "en" as const;
---
<Base
  lang={lang}
  path="terms"
  localized={false}
  title="Terms of Service | Aptelle"
  description="The terms that apply when you use the Aptelle website and join the waitlist."
>
  <Header lang={lang} path="terms" />
  <main id="main">
    <article class="wrap legal">
      <h1>Terms of Service</h1>
      <p class="updated">Last updated 19 June 2026</p>

      <p>These terms apply to your use of the Aptelle website. By using the site or joining the waitlist, you agree to them.</p>

      <h2>Pre-launch status</h2>
      <p>Aptelle is in development. The product described on this site is not yet available, and features, timing, and details may change. Joining the waitlist does not guarantee access, pricing, or any specific feature.</p>

      <h2>Using the site</h2>
      <p>Use the site lawfully and do not attempt to disrupt, attack, or misuse it. Provide an email address you are entitled to use when joining the waitlist.</p>

      <h2>Intellectual property</h2>
      <p>The Aptelle name, content, and design are owned by us. You may not copy or reuse them without permission.</p>

      <h2>No warranties</h2>
      <p>The site is provided "as is" without warranties of any kind. We do not promise it will be uninterrupted or error-free.</p>

      <h2>Limitation of liability</h2>
      <p>To the extent permitted by law, we are not liable for indirect or consequential losses arising from your use of the site.</p>

      <h2>Changes</h2>
      <p>We may update these terms as the product develops. Continued use after a change means you accept the updated terms.</p>

      <h2>Contact</h2>
      <p>Questions about these terms can go to <a href="mailto:hello@aptelle.com">hello@aptelle.com</a>.</p>
    </article>
  </main>
  <Footer lang={lang} />
</Base>
