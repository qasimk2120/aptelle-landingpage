---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import StatusPage from "../components/StatusPage.astro";
import Footer from "../components/Footer.astro";
import { t, localeHref } from "../i18n/ui";
const lang = "en" as const;
const s = t(lang);
---
<Base lang={lang} path="joined" title={s.joinedTitle} description={s.joinedBody} noindex>
  <Header lang={lang} path="joined" />
  <main id="main">
    <StatusPage
      eyebrow={s.eyebrow}
      h1={s.joinedH1}
      body={s.joinedBody}
      ctaHref="/validate"
      ctaLabel="Shape what we build first · 2 min"
      icon="lucide:clipboard-list"
      subHref={localeHref(lang)}
      subLabel={s.backHome}
    />
  </main>
  <Footer lang={lang} />
</Base>
