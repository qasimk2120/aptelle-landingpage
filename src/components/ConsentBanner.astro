---
import { t, type Lang } from "../i18n/ui";
interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang);
---
<div id="cookieBanner" class="cookieBanner" role="dialog" aria-live="polite" aria-label="Cookie consent" hidden>
  <div class="wrap cookieRow">
    <p class="cookieText">
      {s.cookieText} <a href="/privacy">{s.privacy}</a>
    </p>
    <div class="cookieBtns">
      <button type="button" id="cookieReject" class="cbtn cbtn-ghost">{s.cookieReject}</button>
      <button type="button" id="cookieAccept" class="cbtn cbtn-gold">{s.cookieAccept}</button>
    </div>
  </div>
</div>

<script>
  const KEY = "aptelle-cookie-consent";
  const banner = document.getElementById("cookieBanner");

  function loadGated() {
    document.querySelectorAll<HTMLIFrameElement>("[data-consent-src]").forEach((el) => {
      if (!el.getAttribute("src")) el.setAttribute("src", el.dataset.consentSrc || "");
      el.hidden = false;
    });
    document.querySelectorAll<HTMLElement>("[data-consent-hide]").forEach((el) => {
      el.hidden = true;
    });
  }

  function decide(value: "accepted" | "rejected") {
    try { localStorage.setItem(KEY, value); } catch (e) {}
    if (banner) banner.hidden = true;
    if (value === "accepted") loadGated();
  }

  const saved = (() => { try { return localStorage.getItem(KEY); } catch (e) { return null; } })();
  if (saved === "accepted") {
    loadGated();
  } else if (saved !== "rejected" && banner) {
    banner.hidden = false;
  }

  document.getElementById("cookieAccept")?.addEventListener("click", () => decide("accepted"));
  document.getElementById("cookieReject")?.addEventListener("click", () => decide("rejected"));
</script>

<style>
  .cookieBanner {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 60;
    background: rgba(17, 17, 20, 0.96);
    border-top: 1px solid var(--line);
    backdrop-filter: blur(8px);
  }
  .cookieRow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px 24px;
    padding-block: 14px;
  }
  .cookieText {
    margin: 0;
    max-width: 80ch;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .cookieText a {
    color: var(--champagne);
    text-decoration: underline;
  }
  .cookieBtns {
    display: flex;
    gap: 10px;
    flex: none;
  }
  .cbtn {
    min-height: 40px;
    padding: 9px 20px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.92rem;
    cursor: pointer;
    transition: filter 0.18s ease, background 0.18s ease;
  }
  .cbtn-gold {
    border: 1px solid rgba(255, 232, 179, 0.5);
    background: linear-gradient(118deg, var(--bronze) 0%, var(--gold) 52%, var(--soft-gold) 100%);
    color: var(--bg);
  }
  .cbtn-gold:hover { filter: brightness(1.08); }
  .cbtn-ghost {
    border: 1px solid var(--line);
    background: transparent;
    color: var(--muted-strong);
  }
  .cbtn-ghost:hover { background: rgba(255, 255, 255, 0.05); }
</style>
