---
import { t, type Lang } from "../i18n/ui";
interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang);
---
<aside class="card" aria-label="Aptelle size recommendation example">
  <div class="row">
    <div>
      <div class="label">{s.cardLabel}</div>
      <div class="brandrow">
        <span class="bbadge" id="bb" aria-hidden="true">Z</span>
        <span class="brandname" id="bn">Zara</span>
      </div>
    </div>
    <div class="ring" role="img" aria-label={s.confidence}>
      <svg width="118" height="118" viewBox="0 0 118 118" aria-hidden="true">
        <circle cx="59" cy="59" r="52" fill="none" stroke="#2D2D31" stroke-width="10"></circle>
        <circle id="prog" cx="59" cy="59" r="52" fill="none" stroke="#C09047" stroke-width="10" stroke-linecap="round" stroke-dasharray="326.7" stroke-dashoffset="326.7"></circle>
      </svg>
      <div class="pct"><b id="pct">0%</b><span>{s.confidence}</span></div>
    </div>
  </div>
  <div class="sizeline">
    <span class="big" id="size">M</span>
    <span class="small">{s.cardNote}</span>
  </div>
  <div class="chips" aria-hidden="true">
    {s.chips.map((c) => <span class="chip">{c}</span>)}
  </div>
</aside>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const data = [
    { brand: "Zara", size: "M", pct: 96 },
    { brand: "Levi's", size: "31", pct: 92 },
    { brand: "Uniqlo", size: "L", pct: 94 },
    { brand: "COS", size: "M", pct: 89 },
    { brand: "Nike", size: "10", pct: 97 },
  ];
  const C = 2 * Math.PI * 52;
  const prog = document.getElementById("prog") as unknown as SVGCircleElement | null;
  const pctEl = document.getElementById("pct");
  const bn = document.getElementById("bn");
  const bb = document.getElementById("bb");
  const sizeEl = document.getElementById("size");
  let i = 0;
  function setRing(target: number) {
    if (!prog || !pctEl) return;
    if (reduce) { prog.style.strokeDashoffset = String(C * (1 - target / 100)); pctEl.textContent = target + "%"; return; }
    let start: number | null = null;
    const from = parseFloat(pctEl.textContent || "0") || 0;
    function step(ts: number) {
      if (!start) start = ts;
      const tt = Math.min((ts - start) / 900, 1);
      const eased = 1 - Math.pow(1 - tt, 3); // ease-out cubic: decelerates into the target
      const val = Math.round(from + (target - from) * eased);
      pctEl!.textContent = val + "%";
      prog!.style.strokeDashoffset = String(C * (1 - val / 100));
      if (tt < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const swapEls = [bn, bb, sizeEl].filter(Boolean) as HTMLElement[];
  function setText(d: (typeof data)[number]) {
    if (bn) bn.textContent = d.brand;
    if (bb) bb.textContent = d.brand.charAt(0).toUpperCase();
    if (sizeEl) sizeEl.textContent = d.size;
  }
  function render(first = false) {
    const d = data[i];
    if (first || reduce) { setText(d); setRing(d.pct); return; }
    swapEls.forEach((el) => el.classList.add("swap"));
    setTimeout(() => {
      setText(d);
      swapEls.forEach((el) => el.classList.remove("swap"));
    }, 300);
    setRing(d.pct);
  }
  render(true);
  if (!reduce) setInterval(() => { i = (i + 1) % data.length; render(); }, 3400);
</script>
