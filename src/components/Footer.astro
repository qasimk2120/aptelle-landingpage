---
import { t, type Lang } from "../i18n/ui";
interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang);
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap frow">
    <div class="fcopy">&copy; {year} <span translate="no">Apt<span class="elle">Elle</span></span>. {s.rights}</div>
    <div class="fproj">{s.projectPre}<a href="https://cognielevate.co" rel="noopener" translate="no">CogniElevate</a>{s.projectPost}</div>
    <nav class="fnav" aria-label="Footer">
      <a href="/privacy">{s.privacy}</a>
      <a href="/terms">{s.terms}</a>
      <a href="mailto:hello@aptelle.com">hello@aptelle.com</a>
    </nav>
  </div>
</footer>
