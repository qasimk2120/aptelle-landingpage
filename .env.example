# Get these values from Supabase Dashboard > Project Settings > API.
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Cloudflare Turnstile site key (public). Create a widget for aptelle.com at
# Cloudflare Dashboard > Turnstile. The matching secret is NOT set here - it
# goes into Supabase secrets: npx supabase secrets set TURNSTILE_SECRET=...
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
